# Local API
PORT=8787
ADMIN_TOKEN=replace-with-admin-review-password
PUBLIC_ORIGINS=http://127.0.0.1:4174,http://localhost:4174
OPS_DB_PATH=apps/api/data/ops-assets.sqlite
DATA_SOURCE=sqlite

# Feishu data source. Keep DATA_SOURCE=sqlite until all values are ready.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_APP_TOKEN=
FEISHU_ASSETS_TABLE_ID=
FEISHU_SUBMISSIONS_TABLE_ID=
FEISHU_DUPLICATES_TABLE_ID=
FEISHU_AUDIT_TABLE_ID=
FEISHU_WIKI_HOME_URL=https://flova-team.feishu.cn/wiki/F6fewvK1nitUoLkphfRc4xE4n3b

# Static frontend build, when deploying the web app separately.
# Use "same-origin" when the API server also serves apps/web.
PUBLIC_API_BASE=same-origin
