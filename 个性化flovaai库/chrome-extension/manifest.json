{
  "manifest_version": 3,
  "name": "Flova Skill 与原生 @ 助手",
  "version": "0.4.0",
  "description": "在 Flova 项目页搜索公开 Skill、我的 Skill 和资产库；资产只通过 Flova 原生 @ 选择器插入。",
  "permissions": [],
  "host_permissions": [
    "https://www.flova.ai/*",
    "https://service.flova.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.flova.ai/*"
      ],
      "js": [
        "flova-utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://www.flova.ai/*"
      ]
    }
  ]
}
