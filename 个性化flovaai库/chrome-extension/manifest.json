{
  "manifest_version": 3,
  "name": "Flova Skill 与资产桥接器",
  "version": "0.3.0",
  "description": "在 Flova 项目页搜索公开 Skill、我的 Skill 和资产库，组合主 Skill、辅助 Skill 与资产引用后插入到对话输入框。",
  "permissions": [],
  "host_permissions": [
    "https://www.flova.ai/*",
    "https://service.flova.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.flova.ai/*"
      ],
      "js": [
        "flova-utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://www.flova.ai/*"
      ]
    }
  ]
}
